APP_NAME=EstateX API
DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/estatex

JWT_SECRET_KEY=replace_with_secure_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

UPLOADS_DIR=uploads

BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_CLIENT_SCRIPT=../blockchain/scripts/estatexClient.js
CHAIN_RPC_URL=http://127.0.0.1:8545
CHAIN_PRIVATE_KEY=
CHAIN_CONTRACT_ADDRESS=
